# ===============================
# مؤسسة الذهبية - Environment Variables
# ===============================

# MongoDB Connection String
# For local: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.xxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017

# Database name
DB_NAME=alzahabiya

# Admin dashboard password (change this in production!)
ADMIN_PASSWORD=admin2025

# Public base URL (used for OG tags / sitemap). For Vercel it will be set automatically.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# CORS origins (comma-separated) or *
CORS_ORIGINS=*
